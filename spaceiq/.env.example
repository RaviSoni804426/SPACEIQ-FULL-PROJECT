# SpaceBook shared environment template
# Copy this file to `spaceiq/.env` for backend/local Docker usage.
# Copy the NEXT_PUBLIC_* values into `spaceiq/frontend/.env.local` for local Next.js dev.

# App
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Database
# Local default uses SQLite for a zero-setup run.
# Swap to Postgres in Docker/production.
DATABASE_URL=sqlite:///./spaceiq.db

# Auth
SECRET_KEY=replace-this-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# Google
# Leave blank locally to let Partner Hub seed demo Bangalore inventory instead.
GOOGLE_PLACES_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Razorpay
# Leave blank locally to use demo checkout without a live Razorpay account.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Redis / Upstash
# Leave blank locally unless you have Redis running.
REDIS_URL=
HOLD_DURATION_SECONDS=300
SLOT_SWEEP_INTERVAL_SECONDS=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# SpaceIQ Lite environment template
# Copy this file to `spaceiq/.env`
# Copy NEXT_PUBLIC_* values to `spaceiq/frontend/.env.local`

# App
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=sqlite:///./spaceiq.db

# Auth
SECRET_KEY=replace-this-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# Booking orchestration
HOLD_DURATION_SECONDS=300
SLOT_SWEEP_INTERVAL_SECONDS=60
REDIS_URL=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
